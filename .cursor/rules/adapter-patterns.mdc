## Migration Guide

### Creating a New Adapter

Follow these steps to create a new adapter that follows all the rules:

#### 1. Create Directory Structure

```bash
# For any adapter (even single-interface)
mkdir -p packages/routecraft/src/adapters/yourAdapter
cd packages/routecraft/src/adapters/yourAdapter

# Core files
touch index.ts    # Factory function + exports
touch types.ts    # Type definitions (if needed)

# Add operation files based on support
touch source.ts       # If supporting Source
touch destination.ts  # If supporting Destination
touch shared.ts       # If sharing logic between operations
```

#### 2. Implement Adapter Classes

**For Source support (`source.ts`):**
```typescript
import type { Source, CallableSource, CraftContext, Exchange, ExchangeHeaders } from '../../types';

export class YourAdapterSourceAdapter<T> implements Source<T> {
  readonly adapterId = "routecraft.adapter.youradapter";

  constructor(
    private param1: Type1,
    private param2?: Type2,
  ) {}

  subscribe: CallableSource<T> = async (context, handler, abortController, onReady) => {
    try {
      onReady?.();

      while (!abortController.signal.aborted) {
        const message = await this.getNextMessage();
        await handler(message);
      }
    } catch (error) {
      if (!abortController.signal.aborted) throw error;
    }
  };
}
```

**For Destination support (`destination.ts`):**
```typescript
import type { Destination, CallableDestination, Exchange } from '../../types';

export class YourAdapterDestinationAdapter<T, R = void> implements Destination<T, R> {
  readonly adapterId = "routecraft.adapter.youradapter";

  constructor(private config: ConfigType) {}

  send: CallableDestination<T, R> = async (exchange) => {
    const result = await this.processExchange(exchange);
    return result;
  };
}
```

**For shared logic (`shared.ts`):**
```typescript
// Extract common helpers used by both source and destination
export function getYourAdapterChannel(context: CraftContext, endpoint: string) {
  // Shared logic
}
```

#### 3. Create Factory Function

**Single-interface factory (`index.ts`):**
```typescript
import type { Source } from '../../operations/from';
import { YourAdapterSourceAdapter } from './source';

export function yourAdapter<T>(
  param1: Type1,
  param2?: Type2,
): Source<T> {
  return new YourAdapterSourceAdapter<T>(param1, param2);
}
```

**Multi-interface factory (`index.ts`):**
```typescript
import type { Source, Destination } from '../../types';
import { YourAdapterSourceAdapter } from './source';
import { YourAdapterDestinationAdapter } from './destination';

// Source overload
export function yourAdapter<S>(
  endpoint: string,
  options: SourceOptions<S>
): Source<Exchange<S>>;

// Destination overload
export function yourAdapter<T, R = void>(
  handler: (exchange: Exchange<T>) => Promise<R> | R
): Destination<T, R>;

// Implementation with structural type guards (Rule 4)
export function yourAdapter<S, T, R = void>(
  ...args: any[]
): Source<Exchange<S>> | Destination<T, R> {
  if (typeof args[0] === 'string' && arguments.length === 2) {
    return new YourAdapterSourceAdapter<S>(args[0], args[1]);
  }
  if (typeof args[0] === 'function') {
    return new YourAdapterDestinationAdapter<T, R>(args[0]);
  }
  throw new Error('Invalid arguments to yourAdapter()');
}
```

#### 4. Export from Package

Add to `packages/routecraft/src/index.ts`:
```typescript
export { yourAdapter } from './adapters/yourAdapter';
export type { YourAdapterOptions } from './adapters/yourAdapter';
```

#### 5. Write Tests

Create `packages/routecraft/test/your-adapter.test.ts`:
```typescript
import { describe, it, expect, vi } from 'vitest';
import { route, simple } from '../src';
import { yourAdapter } from '../src/adapters/yourAdapter';

describe('yourAdapter', () => {
  it('should work as source', async () => {
    const handler = vi.fn();

    await route
      .from(yourAdapter(params))
      .to(handler)
      .start();

    expect(handler).toHaveBeenCalled();
  });

  it('should work as destination', async () => {
    const result = await route
      .from(simple(() => ({ data: 'test' })))
      .to(yourAdapter(config))
      .start();

    expect(result).toBeDefined();
  });
});
```

### Checklist

Before submitting your new adapter:

- [ ] Directory structure follows pattern (operation files + index)
- [ ] Class names use `{Concept}{Operation}Adapter` format
- [ ] Factory returns interface type, not class type
- [ ] Structural type guards used for multi-interface factories
- [ ] Shared logic extracted to `shared.ts` if needed
- [ ] JSDoc documentation added
- [ ] Tests written and passing
- [ ] Exported from package index
- [ ] Callable variant supported (functions accepted as adapters)

