## Examples

### Example 1: Single-Interface Source Adapter (simple)

**File: `packages/routecraft/src/adapters/simple/source.ts`**
```typescript
import type { Source, CallableSource, CraftContext, Exchange, ExchangeHeaders } from '../../types';

export class SimpleSourceAdapter<T> implements Source<T> {
  readonly adapterId = "routecraft.adapter.simple";

  constructor(private producer: () => T | Promise<T>) {}

  subscribe: CallableSource<T> = async (context, handler, abortController, onReady) => {
    try {
      onReady?.();
      const message = await this.producer();
      await handler(message);

      if (!abortController.signal.aborted) {
        abortController.abort();
      }
    } catch (error) {
      if (!abortController.signal.aborted) throw error;
    }
  };
}
```

**File: `packages/routecraft/src/adapters/simple/index.ts`**
```typescript
import type { Source } from '../../operations/from';
import { SimpleSourceAdapter } from './source';

export function simple<T>(producer: () => T | Promise<T>): Source<T> {
  return new SimpleSourceAdapter<T>(producer);
}
```

### Example 2: Multi-Interface Adapter (direct)

**File: `packages/routecraft/src/adapters/direct/source.ts`**
```typescript
import type { Source, CallableSource, Exchange, ExchangeHeaders } from '../../types';
import { getDirectChannel } from './shared';

export class DirectSourceAdapter<S> implements Source<Exchange<S>> {
  readonly adapterId = "routecraft.adapter.direct";

  constructor(
    private endpoint: string,
    private options: DirectServerOptions<S> = {},
  ) {}

  subscribe: CallableSource<Exchange<S>> = async (
    context,
    handler,
    abortController,
    onReady,
  ) => {
    const channel = getDirectChannel(context, this.endpoint);

    channel.on('message', async (data: any) => {
      if (abortController.signal.aborted) return;
      const body = this.options.deserialize?.(data) ?? data;
      const exchange: Exchange<S> = { body, headers: this.options.headers };
      await handler(exchange.body, exchange.headers);
    });

    onReady?.();
  };
}
```

**File: `packages/routecraft/src/adapters/direct/destination.ts`**
```typescript
import type { Destination, CallableDestination, Exchange } from '../../types';

export class DirectDestinationAdapter<T> implements Destination<T, T> {
  readonly adapterId = "routecraft.adapter.direct";

  constructor(
    private endpoint: string | ((exchange: Exchange<T>) => string),
  ) {}

  send: CallableDestination<T, T> = async (exchange) => {
    const endpointStr = typeof this.endpoint === 'function'
      ? this.endpoint(exchange)
      : this.endpoint;

    // Send to channel and wait for response
    const channel = getDirectChannel(exchange.context, endpointStr);
    return await channel.send(exchange);
  };
}
```

**File: `packages/routecraft/src/adapters/direct/shared.ts`**
```typescript
import type { CraftContext } from '../../types';

export const ADAPTER_DIRECT_STORE = Symbol.for("routecraft.adapter.direct.store");

export function getDirectChannel(context: CraftContext, endpoint: string) {
  let store = context.getStore(ADAPTER_DIRECT_STORE);
  if (!store) {
    store = new Map();
    context.setStore(ADAPTER_DIRECT_STORE, store);
  }

  let channel = store.get(endpoint);
  if (!channel) {
    channel = createChannel(endpoint);
    store.set(endpoint, channel);
  }

  return channel;
}
```

**File: `packages/routecraft/src/adapters/direct/index.ts`**
```typescript
import type { Source, Destination, Exchange } from '../../types';
import { DirectSourceAdapter } from './source';
import { DirectDestinationAdapter } from './destination';
import type { DirectServerOptions } from './types';

// Source overload
export function direct<S>(
  endpoint: string,
  options: Partial<DirectServerOptions>
): Source<Exchange<S>>;

// Destination overload
export function direct<T>(
  endpoint: string | ((exchange: Exchange<T>) => string)
): Destination<T, T>;

// Implementation with structural type guards (Rule 4)
export function direct<S, T>(
  endpoint: string | ((exchange: Exchange<T>) => string),
  options?: Partial<DirectServerOptions>,
): Source<Exchange<S>> | Destination<T, T> {
  // Structural check: arguments.length === 2 means Source
  if (arguments.length === 2) {
    return new DirectSourceAdapter<S>(endpoint as string, options!);
  }
  // Otherwise Destination
  return new DirectDestinationAdapter<T>(endpoint);
}

// Re-export types for public API
export type { DirectServerOptions, DirectClientOptions, DirectOptions } from './types';
export { ADAPTER_DIRECT_STORE, ADAPTER_DIRECT_OPTIONS, ADAPTER_DIRECT_REGISTRY } from './shared';
```

