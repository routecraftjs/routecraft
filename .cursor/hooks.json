{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/track-edit.mjs"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop-check.mjs"
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/cleanup.mjs"
      }
    ]
  }
}
