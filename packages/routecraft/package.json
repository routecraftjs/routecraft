{
  "name": "@routecraft/routecraft",
  "version": "0.6.0",
  "description": "Type-safe framework for AI automation: build the tools an agent uses, or the agent itself, in TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@standard-schema/spec": "^1.1.0",
    "lru-cache": "^11.5.1",
    "pino": "^10.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@routecraft/testing": "workspace:^0.6.0",
    "@sinonjs/fake-timers": "^11.3.1",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^6.4.23",
    "@types/papaparse": "^5.5.2",
    "arktype": "^2.2.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.2.0",
    "croner": "^10.0.1",
    "imapflow": "^1.3.5",
    "mailauth": "^4.13.3",
    "mailparser": "^3.9.9",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.5.3",
    "tsdav": "^2.1.5",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "repository": "https://github.com/routecraftjs/routecraft",
  "keywords": [
    "integration",
    "automation",
    "routes",
    "dsl",
    "typescript",
    "camel",
    "data-processing",
    "workflow",
    "middleware"
  ],
  "author": "routecraftjs",
  "license": "Apache-2.0",
  "homepage": "https://routecraft.dev",
  "bugs": "https://github.com/routecraftjs/routecraft/issues",
  "peerDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "cheerio": "^1.2.0",
    "croner": "^10.0.1",
    "imapflow": "^1.0.0",
    "jose": "^6.0.0",
    "mailauth": "^4.0.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.0.0",
    "papaparse": "^5.4.1",
    "pino-pretty": "^13.1.3",
    "tsdav": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "cheerio": {
      "optional": true
    },
    "croner": {
      "optional": true
    },
    "papaparse": {
      "optional": true
    },
    "imapflow": {
      "optional": true
    },
    "mailauth": {
      "optional": true
    },
    "mailparser": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    },
    "pino-pretty": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    },
    "jose": {
      "optional": true
    },
    "tsdav": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
