{
  "name": "@routecraft/routecraft",
  "version": "0.3.0",
  "description": "Type-safe integration and automation framework for TypeScript/Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@routecraft/testing": "workspace:^0.3.0",
    "@standard-schema/spec": "^1.1.0",
    "pino": "^10.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "agent-browser": "^0.17.0",
    "arktype": "^2.2.0",
    "cheerio": "^1.2.0",
    "papaparse": "^5.5.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "repository": "https://github.com/routecraftjs/routecraft",
  "keywords": [
    "integration",
    "automation",
    "routes",
    "dsl",
    "typescript",
    "camel",
    "data-processing",
    "workflow",
    "middleware"
  ],
  "author": "routecraftjs",
  "license": "Apache-2.0",
  "homepage": "https://routecraft.dev",
  "bugs": "https://github.com/routecraftjs/routecraft/issues",
  "peerDependencies": {
    "agent-browser": "^0.15.1",
    "cheerio": "^1.2.0",
    "papaparse": "^5.4.1",
    "pino-pretty": "^13.1.3"
  },
  "optionalDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
