{
  "name": "@routecraft/routecraft",
  "version": "0.5.0",
  "description": "Type-safe integration and automation framework for TypeScript/Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@standard-schema/spec": "^1.1.0",
    "pino": "^10.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@routecraft/testing": "^0.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^6.4.17",
    "@types/papaparse": "^5.5.2",
    "arktype": "^2.2.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.2.0",
    "imapflow": "^1.0.172",
    "mailparser": "^3.7.2",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.5.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "repository": "https://github.com/routecraftjs/routecraft",
  "keywords": [
    "integration",
    "automation",
    "routes",
    "dsl",
    "typescript",
    "camel",
    "data-processing",
    "workflow",
    "middleware"
  ],
  "author": "routecraftjs",
  "license": "Apache-2.0",
  "homepage": "https://routecraft.dev",
  "bugs": "https://github.com/routecraftjs/routecraft/issues",
  "peerDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "croner": "^10.0.1",
    "imapflow": "^1.0.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.0.0",
    "papaparse": "^5.4.1",
    "pino-pretty": "^13.1.3"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "cheerio": {
      "optional": true
    },
    "croner": {
      "optional": true
    },
    "papaparse": {
      "optional": true
    },
    "imapflow": {
      "optional": true
    },
    "mailparser": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    },
    "pino-pretty": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
