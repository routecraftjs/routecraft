{
  "name": "PROJECT_NAME",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "PACKAGE_MANAGER",
  "scripts": {
    "start": "craft --log-level info run index.ts",
    "lint": "eslint .",
    "format": "prettier . --check --ignore-unknown",
