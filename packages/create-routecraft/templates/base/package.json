{
  "name": "PROJECT_NAME",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "PACKAGE_MANAGER",
  "scripts": {
    "build": "tsc",
    "start": "craft run dist/index.js --log-level info",
    "lint": "eslint .",
    "format": "prettier . --check --ignore-unknown",
    "format:write": "prettier . --write --ignore-unknown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@routecraft/routecraft": "ROUTECRAFT_VERSION"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@routecraft/cli": "ROUTECRAFT_VERSION",
    "@routecraft/testing": "ROUTECRAFT_VERSION",
    "@routecraft/eslint-plugin-routecraft": "ROUTECRAFT_VERSION",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
