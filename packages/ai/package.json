{
  "name": "@routecraft/ai",
  "version": "0.6.0",
  "description": "AI and MCP integrations for Routecraft",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "ai": "^6.0.174"
  },
  "devDependencies": {
    "@routecraft/routecraft": "workspace:*",
    "@sinonjs/fake-timers": "^11.3.1",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "ollama-ai-provider-v2": "^3.5.0",
    "vitest": "^4.1.5",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/openai": "^3.0.37",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@routecraft/routecraft": "^0.6.0",
    "express": "^5.0.0",
    "ollama-ai-provider-v2": "^3.3.1",
    "yaml": "^2.8.0"
  },
  "keywords": [
    "routecraft",
    "ai",
    "mcp",
    "tools",
    "llm"
  ],
  "author": "routecraftjs",
  "license": "Apache-2.0",
  "homepage": "https://routecraft.dev",
  "bugs": "https://github.com/routecraftjs/routecraft/issues",
  "repository": "https://github.com/routecraftjs/routecraft",
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@openrouter/ai-sdk-provider": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "ollama-ai-provider-v2": {
      "optional": true
    },
    "yaml": {
      "optional": true
    }
  }
}
