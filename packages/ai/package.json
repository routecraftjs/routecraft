{
  "name": "@routecraft/ai",
  "version": "0.3.0",
  "description": "AI and MCP integrations for RouteCraft",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@routecraft/routecraft": "workspace:^0.3.0",
    "@standard-schema/spec": "^1.1.0",
    "ai": "^6.0.97",
    "ollama-ai-provider-v2": "^3.3.1"
  },
  "devDependencies": {
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@routecraft/routecraft": "*"
  },
  "keywords": [
    "routecraft",
    "ai",
    "mcp",
    "tools",
    "llm"
  ],
  "author": "routecraftjs",
  "license": "Apache-2.0",
  "homepage": "https://routecraft.dev",
  "bugs": "https://github.com/routecraftjs/routecraft/issues",
  "repository": "https://github.com/routecraftjs/routecraft",
  "publishConfig": {
    "access": "public"
  }
}
