{
  "name": "@routecraft/cli",
  "version": "0.6.0",
  "description": "CLI for running Routecraft capabilities",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/tui/app.tsx src/tui/db.ts --format esm --dts --external react --external ink --external bun:sqlite",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@routecraft/routecraft": "workspace:^0.6.0",
    "agent-browser": "^0.17.1",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "imapflow": "^1.3.3",
    "ink": "^5.2.1",
    "jose": "^6.2.3",
    "mailparser": "^3.9.8",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.5.3",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "tsdav": "^2.1.5"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^6.4.23",
    "@types/react": "^18.3.28",
    "ink-testing-library": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "https://github.com/routecraftjs/routecraft",
  "bin": {
    "craft": "./dist/index.js"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "routecraft",
    "cli",
    "routes",
    "automation",
    "typescript"
  ],
  "author": "routecraftjs",
  "license": "Apache-2.0",
  "homepage": "https://routecraft.dev"
}
