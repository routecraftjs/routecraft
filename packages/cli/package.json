{
  "name": "@routecraft/cli",
  "version": "0.4.0",
  "description": "CLI for running Routecraft routes",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/tui/app.tsx src/tui/db.ts --format esm --dts --external react --external ink --external better-sqlite3",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@routecraft/routecraft": "workspace:^0.4.0",
    "agent-browser": "^0.15.1",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "ink": "^5.1.0",
    "papaparse": "^5.4.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "https://github.com/routecraftjs/routecraft",
  "bin": {
    "craft": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.19.0"
  },
  "keywords": [
    "routecraft",
    "cli",
    "routes",
    "automation",
    "typescript"
  ],
  "author": "routecraftjs",
  "license": "Apache-2.0",
  "homepage": "https://routecraft.dev"
}
