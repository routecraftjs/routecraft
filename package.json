{
  "name": "@routecraft/workspace",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:write": "prettier --write . --ignore-unknown",
    "format": "prettier --check . --ignore-unknown",
    "test": "vitest --run --exclude '**/integration.test.ts'",
    "test:coverage": "vitest --run --coverage --exclude '**/integration.test.ts'",
    "test:integration": "vitest --run 'integration.test.ts'",
    "limit:size": "size-limit",
    "prepare": "husky",
    "build": "pnpm -r run build",
    "version:set": "node .github/scripts/set-version.mjs",
    "publish:all": "pnpm run build && pnpm -r publish --no-git-checks",
    "pack:all": "pnpm run build && rm -rf dist && mkdir dist && pnpm -r exec pnpm pack --pack-destination ../../dist",
    "craft": "node packages/cli/dist/index.js --log-level info",
    "docs": "pnpm --filter routecraft.dev dev",
    "all": " pnpm lint --fix && pnpm format:write && pnpm typecheck && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@size-limit/time": "^12.1.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "comment-parser": "^1.4.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ],
    "*.{css,scss,less,html,svg}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": "https://github.com/routecraftjs/routecraft",
  "dependencies": {
    "chokidar": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
